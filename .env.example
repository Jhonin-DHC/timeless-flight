# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/timeless-flight

# Admin auth
AUTH_SECRET=replace-with-long-random-string
ADMIN_EMAIL=admin@timelessflight.com
ADMIN_PASSWORD=replace-with-strong-password

# eBay Browse API (App ID + Cert ID from developer.ebay.com keyset)
# Set EBAY_ENV=sandbox when using Sandbox (SBX) keys; production for live listings.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENV=production

# Scheduled search endpoint protection
CRON_SECRET=replace-with-long-random-string

# Cloudflare R2 image uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=timeless-images
R2_PUBLIC_BASE_URL=https://pub-your-id.r2.dev

# Existing storefront checkout
NEXT_PUBLIC_API_BASE_URL=https://your-api-domain.com
NEXT_PUBLIC_STOREFRONT_CLIENT_ID=timeless-flight
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# SMTP email (verification codes + team sell alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM="Timeless Flight <you@yourdomain.com>"
SMTP_USER=
SMTP_PASS=
# Comma-separated team inboxes for new sell submissions
SELL_NOTIFY_EMAILS=team@yourdomain.com
